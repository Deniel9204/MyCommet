platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

# Workaround (https://github.com/Deniel9204/MyCommet/issues/196):
# livekit_client's `hkdf` podspec pins WebRTC-SDK 144.7559.01 while flutter_webrtc
# pins 144.7559.04. Both are the same m144 milestone, but the exact-version
# mismatch makes `pod install` unresolvable and breaks the macOS build. Align
# livekit's pin to flutter_webrtc's before CocoaPods resolves the dependency
# graph. Remove once upstream coordinates the two plugins' WebRTC-SDK versions.
def align_livekit_webrtc_pin
  livekit_podspec = File.join(__dir__, 'Flutter', 'ephemeral', '.symlinks',
                              'plugins', 'livekit_client', 'macos',
                              'livekit_client.podspec')
  unless File.exist?(livekit_podspec)
    puts "[commet] WARNING: #{livekit_podspec} not found; skipping WebRTC-SDK pin alignment (issue #196)"
    return
  end

  original = File.read(livekit_podspec)
  patched = original.gsub('144.7559.01', '144.7559.04')
  if patched != original
    File.write(livekit_podspec, patched)
    puts "[commet] Aligned livekit_client WebRTC-SDK pin -> 144.7559.04 (issue #196)"
  end
end

target 'Runner' do
  use_frameworks!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))

  # Must run AFTER flutter_install_all_macos_pods: that call is what creates the
  # Flutter/ephemeral/.symlinks/plugins/* symlinks the patch reads. On a clean
  # checkout (e.g. CI) the symlink doesn't exist before this point, so patching
  # any earlier silently no-ops and `pod install` then fails to resolve
  # WebRTC-SDK. It still runs before dependency resolution, which happens once
  # the whole Podfile has been evaluated.
  align_livekit_webrtc_pin

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
  end
end
